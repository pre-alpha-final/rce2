<div class="card clickable-card border-light px-4" @onclick='() => OnClickCardHandler("youtube")'>
    <div class="card-body">
        <h4 class="card-title">Youtube</h4>
        <p class="card-text">Youtube media control</p>
    </div>
</div>
<div class="card clickable-card border-light px-4" @onclick='() => OnClickCardHandler("placeholder")'>
    <div class="card-body">
        <h4 class="card-title">Placeholder</h4>
        <p class="card-text">placeholder</p>
    </div>
</div>
<div class="card clickable-card border-light px-4" @onclick='() => OnClickCardHandler("placeholder")'>
    <div class="card-body">
        <h4 class="card-title">Placeholder</h4>
        <p class="card-text">placeholder</p>
    </div>
</div>
<div class="card clickable-card border-light px-4" @onclick='() => OnClickCardHandler("placeholder")'>
