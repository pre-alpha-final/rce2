<div class="card clickable-card border-light px-4" @onclick='() => OnClickCardHandler("sendit")'>
    <div class="card-body">
        <h4 class="card-title">Send It!</h4>
        <p class="card-text">Send debug signals</p>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnClickCard { get; set; }

    private async Task OnClickCardHandler(string cardId)
    {
        await OnClickCard.InvokeAsync(cardId);
    }
}
